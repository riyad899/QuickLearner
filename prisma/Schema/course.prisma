model Course {
  id           Int        @id @default(autoincrement())
  title        String     @db.VarChar(255)
  description  String?    @db.Text
  thumbnail    String?    @db.VarChar(255)
  duration     Int?       // Duration in minutes
  slug String @unique
  fee          Decimal?   @db.Decimal(10, 2)
  status       String     @default("draft")
  isDeleted    Boolean    @default(false)
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  instructorID Int
  instructor   Instructor @relation(fields: [instructorID], references: [id], onDelete: Cascade, onUpdate: Cascade)
  students     Student[]

  @@index([title], name: "idx_course_title")
  @@index([instructorID], name: "idx_course_instructor")
  @@index([status], name: "idx_course_status")
  @@index([isDeleted], name: "idx_course_isDeleted")
  @@map("courses")
}
