model Speciality {
  id        String   @id @default(uuid())
  title       String   @unique @db.VarChar(255)
  description String   @db.Text

  icon       String   @db.VarChar(255)
  instructors Instructor[]
  instructorSpecialities InstructorSpeciality[]



  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean  @default(false)
  deletedAt DateTime?

  @@index([title], name: "title_index")
  @@index([isDeleted], name: "isDeleted_index")
  @@map("spacialities")

}

model InstructorSpeciality{
  id String @id @default(uuid())
  instructorId Int
  specialityId String

  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  speciality Speciality @relation(fields: [specialityId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([instructorId], name: "instructorId_index")
  @@index([specialityId], name: "specialityId_index")
  @@map("instructor_speciality")
}